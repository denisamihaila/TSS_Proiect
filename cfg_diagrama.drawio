    <mxCell id="title" value="CFG - evaluate_client_package()"
      style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=26;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="420" y="15" width="560" height="40" as="geometry"/>
    </mxCell>

    <mxCell id="blocks" value="&lt;b&gt;Blocuri numerotate&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;1 Start&lt;br/&gt;2 if date pachet invalide&lt;br/&gt;3 ValueError: invalid package data&lt;br/&gt;4 initializare contoare&lt;br/&gt;5 for: mai exista status?&lt;br/&gt;6 if status invalid&lt;br/&gt;7 ValueError: invalid session status&lt;br/&gt;8 if status == &amp;quot;attended&amp;quot;&lt;br/&gt;9 attended += 1&lt;br/&gt;10 if status == &amp;quot;no_show&amp;quot;&lt;br/&gt;11 no_show += 1&lt;br/&gt;12 if status == &amp;quot;cancelled&amp;quot;&lt;br/&gt;13 cancelled += 1&lt;br/&gt;14 urmatorul status&lt;br/&gt;15 used_sessions = attended + no_show&lt;br/&gt;16 if used_sessions &amp;gt; package_sessions&lt;br/&gt;17 ValueError: used sessions exceed package&lt;br/&gt;18 remaining_sessions si total_cost&lt;br/&gt;19 if has_membership&lt;br/&gt;20 aplica discount&lt;br/&gt;21 if remaining == 0 and no_show == 0&lt;br/&gt;22 status = completed_successfully&lt;br/&gt;23 if remaining == 0&lt;br/&gt;24 status = completed_with_absences&lt;br/&gt;25 status = active&lt;br/&gt;26 return dictionar&lt;br/&gt;27 Stop"
      style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=14;"
      vertex="1" parent="1">
      <mxGeometry x="70" y="70" width="440" height="790" as="geometry"/>
    </mxCell>

