%%{init: {'theme': 'default'}}%%
flowchart TD
    START([START: withdraw&#40;amount&#41;]) --> D1

    D1{D1: not isinstance\namount, int&#124;float}
    D1 -- True --> E1[raise TypeError\n'Suma trebuie sa fie numerica']
    D1 -- False --> D2

    D2{D2: amount &lt;= 0}
    D2 -- True --> E2[raise ValueError\n'Suma de retras trebuie sa fie pozitiva']
    D2 -- False --> D3

    D3{D3: daily_withdrawn + amount\n&gt; MAX_DAILY_WITHDRAWAL}
    D3 -- True --> E3[raise ValueError\n'Limita zilnica depasita']
    D3 -- False --> COMPUTE

    COMPUTE[new_balance = balance - amount\noverdraft_limit = OVERDRAFT_LIMIT\[account_type\]]

    COMPUTE --> D4

    D4{D4: new_balance\n&lt; overdraft_limit}
    D4 -- True --> E4[raise ValueError\n'Fonduri insuficiente']
    D4 -- False --> UPDATE

    UPDATE[balance = new_balance\ndaily_withdrawn += amount\ntransactions_count += 1]

    UPDATE --> RETURN[return balance]
    RETURN --> END([END])

    E1 --> END
    E2 --> END
    E3 --> END
    E4 --> END

    style START fill:#4CAF50,color:#fff
    style END   fill:#4CAF50,color:#fff
    style E1    fill:#F44336,color:#fff
    style E2    fill:#F44336,color:#fff
    style E3    fill:#F44336,color:#fff
    style E4    fill:#F44336,color:#fff
    style UPDATE fill:#2196F3,color:#fff
    style RETURN fill:#2196F3,color:#fff

    subgraph Cai["Cai independente (V(G) = 4 + 1 = 5)"]
        direction LR
        P1["P1: D1=T → TypeError"]
        P2["P2: D1=F, D2=T → ValueError pozitiva"]
        P3["P3: D1=F, D2=F, D3=T → ValueError zilnica"]
        P4["P4: D1=F, D2=F, D3=F, D4=T → ValueError insuficiente"]
        P5["P5: D1=F, D2=F, D3=F, D4=F → succes"]
    end
