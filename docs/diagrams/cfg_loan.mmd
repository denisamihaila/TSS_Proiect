%%{init: {'theme': 'default'}}%%
flowchart TD
    START([START: is_eligible_for_loan&#40;loan_amount&#41;]) --> D1

    D1{D1: not isinstance\nloan_amount, int&#124;float}
    D1 -- True --> E1[raise TypeError\n'Suma creditului trebuie sa fie numerica']
    D1 -- False --> D2

    D2{D2: loan_amount &lt;= 0}
    D2 -- True --> E2[raise ValueError\n'Suma creditului trebuie sa fie pozitiva']
    D2 -- False --> D3

    D3{D3: balance &lt;= 0}
    D3 -- True --> R1[return False\n'sold insuficient']
    D3 -- False --> D4

    D4{D4: transactions_count\n&lt; MIN_TRANSACTIONS_FOR_LOAN}
    D4 -- True --> R2[return False\n'prea putine tranzactii']
    D4 -- False --> COMPUTE

    COMPUTE[max_loan = balance\n* LOAN_MULTIPLIER\[account_type\]]

    COMPUTE --> D5

    D5{D5: loan_amount\n&gt; max_loan}
    D5 -- True --> R3[return False\n'suma prea mare']
    D5 -- False --> R4[return True\n'eligibil pentru credit']

    R1 --> END([END])
    R2 --> END
    R3 --> END
    R4 --> END
    E1 --> END
    E2 --> END

    style START fill:#4CAF50,color:#fff
    style END   fill:#4CAF50,color:#fff
    style E1    fill:#F44336,color:#fff
    style E2    fill:#F44336,color:#fff
    style R1    fill:#FF9800,color:#fff
    style R2    fill:#FF9800,color:#fff
    style R3    fill:#FF9800,color:#fff
    style R4    fill:#4CAF50,color:#fff
    style COMPUTE fill:#2196F3,color:#fff

    subgraph Cai["Cai independente (V(G) = 5 + 1 = 6)"]
        direction LR
        P1["P1: D1=T → TypeError"]
        P2["P2: D1=F, D2=T → ValueError"]
        P3["P3: D1=F, D2=F, D3=T → False (sold)"]
        P4["P4: ..., D4=T → False (tranzactii)"]
        P5["P5: ..., D4=F, D5=T → False (suma)"]
        P6["P6: toate False → True"]
    end
